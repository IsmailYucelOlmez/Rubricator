## 4. Repository — cache + retry + exponential backoff

```dart
class BooksRepository {
  final http.Client _client;
  final String _apiKey;
  final _cache = <String, List<BookModel>>{};

  BooksRepository({required http.Client client, required String apiKey})
      : _client = client,
        _apiKey = apiKey;

  Future<List<BookModel>> search(
    String query, {
    String lang = 'tr',
    int maxResults = 40,
    String orderBy = 'relevance', // 'relevance' | 'newest'
  }) async {
    final cacheKey = '$query|$lang|$maxResults|$orderBy';
    if (_cache.containsKey(cacheKey)) return _cache[cacheKey]!;

    final uri = Uri.https('www.googleapis.com', '/books/v1/volumes', {
      'q': query,
      'printType': 'books',
      'langRestrict': lang,
      'maxResults': '$maxResults',
      'orderBy': orderBy,
      'key': _apiKey,
    });

    final raw = await _fetchWithRetry(uri);
    final items = (raw['items'] as List<dynamic>? ?? [])
        .cast<Map<String, dynamic>>()
        .map(BookModel.fromJson)
        .toList();

    final result = deduplicate(items);
    _cache[cacheKey] = result;
    return result;
  }

  Future<Map<String, dynamic>> _fetchWithRetry(Uri uri) async {
    for (var attempt = 0; attempt < 3; attempt++) {
      final response = await _client.get(uri);

      if (response.statusCode == 200) {
        return jsonDecode(response.body) as Map<String, dynamic>;
      }

      if (response.statusCode == 429 || response.statusCode >= 500) {
        // Exponential backoff: 1s, 2s, 4s
        await Future.delayed(Duration(seconds: 1 << attempt));
        continue;
      }

      throw BooksApiException(
        statusCode: response.statusCode,
        message: 'API hatası: ${response.statusCode}',
      );
    }
    throw const BooksApiException(message: 'Maksimum deneme sayısına ulaşıldı');
  }
}

class BooksApiException implements Exception {
  final int? statusCode;
  final String message;
  const BooksApiException({this.statusCode, required this.message});
}
```

