## 2. Null-safe model

`volumeInfo` alanlarına hiçbir zaman doğrudan erişme. Tüm alanlar opsiyonel olarak tanımlanmalı:

```dart
class BookModel {
  final String id;
  final String title;
  final String? subtitle;
  final List<String> authors;
  final String? publishedYear;
  final int? pageCount;
  final String? coverUrl;
  final String? isbn13;
  final String? language;
  final double? averageRating;
  final String? description;

  const BookModel({
    required this.id,
    required this.title,
    this.subtitle,
    required this.authors,
    this.publishedYear,
    this.pageCount,
    this.coverUrl,
    this.isbn13,
    this.language,
    this.averageRating,
    this.description,
  });

  factory BookModel.fromJson(Map<String, dynamic> json) {
    final v = (json['volumeInfo'] as Map<String, dynamic>?) ?? {};

    // ISBN-13'ü industryIdentifiers listesinden güvenli çek
    final identifiers = v['industryIdentifiers'] as List<dynamic>? ?? [];
    final isbn13 = identifiers
        .cast<Map<String, dynamic>>()
        .firstWhere(
          (id) => id['type'] == 'ISBN_13',
          orElse: () => {},
        )['identifier'] as String?;

    // Kapak URL'sini https'e zorla
    final rawCover = (v['imageLinks'] as Map<String, dynamic>?)?['thumbnail'] as String?;
    final coverUrl = rawCover?.replaceFirst('http://', 'https://');

    // Yayın yılını tam tarihten ayır
    final rawDate = v['publishedDate'] as String?;
    final year = rawDate != null && rawDate.length >= 4 ? rawDate.substring(0, 4) : null;

    return BookModel(
      id: json['id'] as String? ?? '',
      title: v['title'] as String? ?? 'Başlık yok',
      subtitle: v['subtitle'] as String?,
      authors: (v['authors'] as List<dynamic>?)?.cast<String>() ?? [],
      publishedYear: year,
      pageCount: v['pageCount'] as int?,
      coverUrl: coverUrl,
      isbn13: isbn13,
      language: v['language'] as String?,
      averageRating: (v['averageRating'] as num?)?.toDouble(),
      description: v['description'] as String?,
    );
  }
}
```

